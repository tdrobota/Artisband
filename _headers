# Cloudflare Pages custom headers
# https://developers.cloudflare.com/pages/configuration/headers/
# This file must live at the root of the published site (same level as index.html)

# ---- Security headers on everything ----
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://i.ytimg.com; font-src 'self' https://fonts.gstatic.com; media-src 'self'; connect-src 'self'; frame-src https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# ---- Caching ----
# HTML: always revalidate, since page content can change
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Images, videos, fonts: rarely change once published — safe to cache hard
/images/*
  Cache-Control: public, max-age=31536000, immutable

/videos/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS: NOT hashed filenames in this export, so a long "immutable" cache here
# would mean returning visitors don't see updates until the cache expires.
# Keeping this short until you adopt cache-busting (see note below).
/css/*
  Cache-Control: public, max-age=86400, must-revalidate

/js/*
  Cache-Control: public, max-age=86400, must-revalidate
